@model OncallRota.Models.HolidayCalendar
@{ Layout = "~/Views/Shared/_AdminLayout.cshtml"; ViewData["Title"] = "Edit Holiday"; }
<div class="page-header"><h1 class="page-title"><i class="bi bi-pencil me-2 text-primary"></i>Edit Holiday</h1></div>
<div class="page-body"><div class="row justify-content-center"><div class="col-lg-5">
<div class="card"><div class="card-header fw-semibold">Holiday Details</div><div class="card-body">
<form asp-action="Edit" method="post">@Html.AntiForgeryToken()
<input asp-for="HolidayId" type="hidden"/>
<div class="mb-3"><label asp-for="HolidayName" class="form-label"></label><input asp-for="HolidayName" class="form-control"/></div>
<div class="mb-3"><label asp-for="HolidayDate" class="form-label"></label><input asp-for="HolidayDate" type="date" class="form-control"/></div>
<div class="mb-3"><label asp-for="Location" class="form-label"></label>
<select asp-for="Location" class="form-select"><option value="">All Locations</option><option>Bangalore</option><option>Pune</option><option>Hyderabad</option><option>Kolkata</option><option>Chennai</option></select></div>
<div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
<div class="mb-3"><label asp-for="Status" class="form-label"></label><select asp-for="Status" class="form-select"><option value="Active">Active</option><option value="Inactive">Inactive</option></select></div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Update</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
</form></div></div></div></div></div>