@model List<OncallRota.Models.OnCallSchedule>
@{ Layout = "_EmployeeLayout"; ViewData["Title"] = "My Schedule"; }
<div class="page-header">
  <h1 class="page-title"><i class="bi bi-calendar3-week me-2 text-primary"></i>My Schedule</h1>
</div>
<div class="page-body">
  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover datatable mb-0 align-middle">
          <thead class="table-light">
            <tr><th>Team</th><th>Week Start</th><th>Week End</th><th>My Role</th><th>Status</th></tr>
          </thead>
          <tbody>
            @{ var empId = Context.Session.GetInt32("EmployeeId"); }
            @foreach(var s in Model){
              <tr>
                <td>@s.Team?.TeamName</td>
                <td>@s.WeekStartDate?.ToString("dd MMM yyyy")</td>
                <td>@s.WeekEndDate?.ToString("dd MMM yyyy")</td>
                <td>@(s.PrimaryEmployeeId==empId?"Primary On-Call":"Backup On-Call")</td>
                <td><span class="badge-status badge-@s.Status.ToLower()">@s.Status</span></td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
