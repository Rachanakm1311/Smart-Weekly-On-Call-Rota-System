@model IEnumerable<OncallRota.Models.OnCallSchedule>
@{ Layout="_AdminLayout"; ViewData["Title"]="On-Call Schedule"; }
<div class="page-header">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div><h1 class="page-title"><i class="bi bi-calendar3-week me-2 text-primary"></i>On-Call Schedule</h1></div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#generateModal">
      <i class="bi bi-magic me-1"></i>Generate Weekly Rota
    </button>
  </div>
</div>
<div class="page-body">
  <div class="card"><div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover datatable mb-0 align-middle">
        <thead class="table-light">
          <tr><th>Team</th><th>Week Start</th><th>Week End</th><th>Primary</th><th>Backup</th><th>Status</th><th class="text-end">Actions</th></tr>
        </thead>
        <tbody>
          @foreach(var s in Model){
            <tr data-oncall-team="@s.Team?.TeamName"
                data-primary-name="@s.PrimaryEmployee?.EmployeeName"
                data-primary-phone="@s.PrimaryEmployee?.Phone"
                data-backup-name="@s.BackupEmployee?.EmployeeName"
                data-backup-phone="@s.BackupEmployee?.Phone">
              <td class="fw-semibold">@s.Team?.TeamName</td>
              <td>@s.WeekStartDate?.ToString("dd MMM yyyy")</td>
              <td>@s.WeekEndDate?.ToString("dd MMM yyyy")</td>
              <td>
                @if (s.PrimaryEmployee != null) {
                  <div>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">@s.PrimaryEmployee.EmployeeName</span>
                    @if (!string.IsNullOrEmpty(s.PrimaryEmployee.Phone)) {
                      <div class="mt-1">
                        <a href="tel:@s.PrimaryEmployee.Phone" class="text-decoration-none small" style="color:#16a34a">
                          <i class="bi bi-telephone-fill me-1"></i>@s.PrimaryEmployee.Phone
                        </a>
                      </div>
                    } else {
                      <div class="text-muted small mt-1">No phone on record</div>
                    }
                  </div>
                } else { <span class="text-muted">—</span> }
              </td>
              <td>
                @if (s.BackupEmployee != null) {
                  <div>
                    <span class="badge bg-secondary-subtle text-secondary border">@s.BackupEmployee.EmployeeName</span>
                    @if (!string.IsNullOrEmpty(s.BackupEmployee.Phone)) {
                      <div class="mt-1">
                        <a href="tel:@s.BackupEmployee.Phone" class="text-decoration-none small" style="color:#d97706">
                          <i class="bi bi-telephone-fill me-1"></i>@s.BackupEmployee.Phone
                        </a>
                      </div>
                    } else {
                      <div class="text-muted small mt-1">No phone on record</div>
                    }
                  </div>
                } else { <span class="text-muted">—</span> }
              </td>
              <td><span class="badge-status badge-@s.Status.ToLower()">@s.Status</span></td>
              <td class="text-end">
                <form asp-action="Delete" asp-route-id="@s.ScheduleId" method="post" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-xs btn-outline-danger" data-confirm="Delete this schedule entry?">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div></div>
</div>
<!-- Generate Rota Modal -->
<div class="modal fade" id="generateModal" tabindex="-1">
  <div class="modal-dialog"><div class="modal-content">
    <form asp-action="GenerateRota" method="post">@Html.AntiForgeryToken()
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-magic me-2 text-primary"></i>Generate Weekly Rota</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label fw-semibold">Select Team</label>
          <select name="teamId" class="form-select">
            <option value="">-- Select Team --</option>
            @if(ViewBag.Teams is IEnumerable<OncallRota.Models.Team> teams){
              @foreach(var t in teams){
                <option value="@t.TeamId">@t.TeamName</option>
              }
            }
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Week Start Date <span class="text-muted small">(must be Monday)</span></label>
          <input type="date" name="weekStart" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")"/>
        </div>
        <div class="alert alert-info small py-2 mb-0">
          <i class="bi bi-info-circle me-1"></i>
          The system will assign Primary and Backup based on the Rotation Queue,
          automatically skipping employees on approved leave.
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary"><i class="bi bi-play-fill me-1"></i>Generate</button>
      </div>
    </form>
  </div></div>
</div>
