@model OncallRota.ViewModels.AdminDashboardViewModel
@{ Layout = "_AdminLayout"; ViewData["Title"] = "Admin Dashboard"; var today = DateTime.Today; }

<!-- Page Header -->
<div class="page-header">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item text-muted"><i class="bi bi-house me-1"></i>Home</li>
          <li class="breadcrumb-item active">Dashboard</li>
        </ol>
      </nav>
      <h1 class="page-title"><i class="bi bi-speedometer2 me-2 text-primary"></i>Admin Dashboard</h1>
      <p class="page-subtitle">Smart Weekly On-Call Rota Management System</p>
    </div>
    <div class="d-flex align-items-center gap-2">
      <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2"
            style="font-size:.75rem;font-weight:600">
        <i class="bi bi-circle-fill me-1" style="font-size:.45rem"></i>System Online
      </span>
    </div>
  </div>
</div>

<div class="page-body">

  <!-- Greeting Banner -->
  <div class="greeting-banner">
    <div class="row align-items-center g-3">
      <div class="col-lg-8">
        <div class="greeting-banner__badge mb-2">
          <i class="bi bi-calendar3"></i>@today.ToString("dddd, dd MMMM yyyy")
        </div>
        <div class="greeting-banner__title">
          Good @(DateTime.Now.Hour < 12 ? "Morning" : DateTime.Now.Hour < 17 ? "Afternoon" : "Evening"),
          @Context.Session.GetString("EmployeeName") 👋
        </div>
        <div class="greeting-banner__sub">
          Here's an overview of your on-call rota system — @Model.CurrentWeekSchedules.Count team@(Model.CurrentWeekSchedules.Count!=1?"s are":"is") currently active this week.
        </div>
      </div>
      <div class="col-lg-4 d-none d-lg-flex justify-content-end">
        <div class="d-flex gap-4" style="color:rgba(255,255,255,.9)">
          <div class="text-center">
            <div style="font-size:2rem;font-weight:800;line-height:1">@Model.PendingLeaveRequests</div>
            <div style="font-size:.7rem;opacity:.75;text-transform:uppercase;letter-spacing:.06em;margin-top:3px">Pending Leaves</div>
          </div>
          <div style="width:1px;background:rgba(255,255,255,.2)"></div>
          <div class="text-center">
            <div style="font-size:2rem;font-weight:800;line-height:1">@Model.PendingSwapRequests</div>
            <div style="font-size:.7rem;opacity:.75;text-transform:uppercase;letter-spacing:.06em;margin-top:3px">Pending Swaps</div>
          </div>
          <div style="width:1px;background:rgba(255,255,255,.2)"></div>
          <div class="text-center">
            <div style="font-size:2rem;font-weight:800;line-height:1">@Model.TotalEmployees</div>
            <div style="font-size:.7rem;opacity:.75;text-transform:uppercase;letter-spacing:.06em;margin-top:3px">Employees</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- KPI Grid -->
  <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;padding-bottom:8px;border-bottom:1px solid #e2e8f0;margin-bottom:16px">
    Key Metrics
  </div>
  <div class="row g-3 mb-4">
    <div class="col-6 col-xl-3">
      <a asp-controller="Teams" asp-action="Index" class="text-decoration-none">
        <div class="kpi kpi--blue">
          <div class="kpi__icon"><i class="bi bi-people-fill"></i></div>
          <div>
            <div class="kpi__val">@Model.TotalTeams</div>
            <div class="kpi__lbl">Active Teams</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-xl-3">
      <a asp-controller="Employees" asp-action="Index" class="text-decoration-none">
        <div class="kpi kpi--green">
          <div class="kpi__icon"><i class="bi bi-person-badge-fill"></i></div>
          <div>
            <div class="kpi__val">@Model.TotalEmployees</div>
            <div class="kpi__lbl">Employees</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-xl-3">
      <a asp-controller="Applications" asp-action="Index" class="text-decoration-none">
        <div class="kpi kpi--purple">
          <div class="kpi__icon"><i class="bi bi-app-indicator"></i></div>
          <div>
            <div class="kpi__val">@Model.TotalApplications</div>
            <div class="kpi__lbl">Applications</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-xl-3">
      <div class="kpi kpi--amber">
        <div class="kpi__icon"><i class="bi bi-calendar-x"></i></div>
        <div>
          <div class="kpi__val">@Model.EmployeesOnLeave</div>
          <div class="kpi__lbl">On Leave Today</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-xl-3">
      <a asp-controller="Schedule" asp-action="Index" class="text-decoration-none">
        <div class="kpi kpi--cyan">
          <div class="kpi__icon"><i class="bi bi-calendar3-week"></i></div>
          <div>
            <div class="kpi__val">@Model.CurrentWeekSchedules.Count</div>
            <div class="kpi__lbl">Current On-Call</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-xl-3">
      <a asp-controller="LeaveRequests" asp-action="Index" class="text-decoration-none">
        <div class="kpi kpi--red">
          <div class="kpi__icon"><i class="bi bi-clock-history"></i></div>
          <div>
            <div class="kpi__val">@Model.PendingLeaveRequests</div>
            <div class="kpi__lbl">Pending Leaves</div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-6 col-xl-3">
      <a asp-controller="ShiftSwap" asp-action="Index" class="text-decoration-none">
        <div class="kpi kpi--amber">
          <div class="kpi__icon"><i class="bi bi-arrow-left-right"></i></div>
          <div>
            <div class="kpi__val">@Model.PendingSwapRequests</div>
            <div class="kpi__lbl">Pending Swaps</div>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- Quick Actions -->
  <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;padding-bottom:8px;border-bottom:1px solid #e2e8f0;margin-bottom:16px">
    Quick Actions
  </div>
  <div class="row g-2 mb-4">
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="Employees" asp-action="Create" class="qa-btn qa-primary">
        <i class="bi bi-person-plus-fill"></i><span>Add Employee</span>
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="Employees" asp-action="Index" class="qa-btn">
        <i class="bi bi-people-fill"></i><span>Manage Employees</span>
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="LeaveRequests" asp-action="Index" class="qa-btn position-relative">
        <i class="bi bi-calendar-check-fill"></i><span>Review Leaves</span>
        @if(Model.PendingLeaveRequests > 0){
          <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger" style="font-size:.58rem">@Model.PendingLeaveRequests</span>
        }
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="ShiftSwap" asp-action="Index" class="qa-btn position-relative">
        <i class="bi bi-arrow-left-right"></i><span>Review Swaps</span>
        @if(Model.PendingSwapRequests > 0){
          <span class="position-absolute top-0 end-0 translate-middle badge rounded-pill bg-danger" style="font-size:.58rem">@Model.PendingSwapRequests</span>
        }
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="Schedule" asp-action="Index" class="qa-btn">
        <i class="bi bi-calendar2-week-fill"></i><span>Generate Rota</span>
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="RotationQueue" asp-action="Index" class="qa-btn">
        <i class="bi bi-arrow-repeat"></i><span>Rotation Queue</span>
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="Teams" asp-action="Create" class="qa-btn">
        <i class="bi bi-plus-circle-fill"></i><span>Add Team</span>
      </a>
    </div>
    <div class="col-6 col-md-3 col-xl-2">
      <a asp-controller="HolidayCalendar" asp-action="Index" class="qa-btn">
        <i class="bi bi-calendar-heart-fill"></i><span>Holidays</span>
      </a>
    </div>
  </div>

  <!-- Current Week Schedule -->
  <div style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#94a3b8;padding-bottom:8px;border-bottom:1px solid #e2e8f0;margin-bottom:16px">
    Current Week On-Call Schedule
  </div>
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span><i class="bi bi-calendar-check me-2 text-primary"></i>
        Week of @today.AddDays(-(int)today.DayOfWeek + (int)DayOfWeek.Monday).ToString("dd MMM") –
        @today.AddDays(-(int)today.DayOfWeek + (int)DayOfWeek.Sunday).ToString("dd MMM yyyy")
      </span>
      <a asp-controller="Schedule" asp-action="Index" class="btn btn-xs btn-outline-primary">
        <i class="bi bi-arrow-right me-1"></i>View All
      </a>
    </div>
    <div class="card-body p-0">
      @if (!Model.CurrentWeekSchedules.Any()) {
        <div class="text-center py-5 text-muted">
          <i class="bi bi-calendar3 fs-1 d-block mb-2 opacity-25"></i>
          <p class="mb-3 fw-semibold">No active on-call schedule for this week.</p>
          <a asp-controller="Schedule" asp-action="Index" class="btn btn-sm btn-primary">
            <i class="bi bi-magic me-1"></i>Generate Rota Now
          </a>
        </div>
      } else {
        <div class="table-responsive">
          <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
              <tr>
                <th>Team</th>
                <th>Week</th>
                <th>Primary On-Call</th>
                <th>Backup On-Call</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var s in Model.CurrentWeekSchedules) {
                <tr>
                  <td class="fw-semibold">
                    <span class="d-flex align-items-center gap-2">
                      <span style="width:8px;height:8px;border-radius:50%;background:#4338ca;flex-shrink:0;display:inline-block"></span>
                      @s.Team?.TeamName
                    </span>
                  </td>
                  <td class="small text-muted">@s.WeekStartDate?.ToString("dd MMM") – @s.WeekEndDate?.ToString("dd MMM yyyy")</td>
                  <td>
                    @if(s.PrimaryEmployee != null){
                      var ppic = s.PrimaryEmployee.ProfilePicture;
                      <div class="d-flex align-items-center gap-2">
                        @if(!string.IsNullOrEmpty(ppic)){
                          <img src="@ppic" class="avatar-sm" style="width:28px;height:28px" alt=""/>
                        } else {
                          <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#4338ca,#0891b2);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.65rem;font-weight:700;flex-shrink:0">@s.PrimaryEmployee.EmployeeName[..1].ToUpper()</div>
                        }
                        <div>
                          <div class="fw-semibold">@s.PrimaryEmployee.EmployeeName</div>
                          @if (!string.IsNullOrEmpty(s.PrimaryEmployee.Phone)) {
                            <a href="tel:@s.PrimaryEmployee.Phone" class="text-decoration-none small text-muted">
                              <i class="bi bi-telephone-fill me-1 text-success" style="font-size:.65rem"></i>@s.PrimaryEmployee.Phone
                            </a>
                          } else {
                            <span class="small text-muted">No phone</span>
                          }
                        </div>
                      </div>
                    }
                  </td>
                  <td>
                    @if(s.BackupEmployee != null){
                      var bpic = s.BackupEmployee.ProfilePicture;
                      <div class="d-flex align-items-center gap-2">
                        @if(!string.IsNullOrEmpty(bpic)){
                          <img src="@bpic" class="avatar-sm" style="width:28px;height:28px" alt=""/>
                        } else {
                          <div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#a78bfa);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.65rem;font-weight:700;flex-shrink:0">@s.BackupEmployee.EmployeeName[..1].ToUpper()</div>
                        }
                        <div>
                          <div>@s.BackupEmployee.EmployeeName</div>
                          @if (!string.IsNullOrEmpty(s.BackupEmployee.Phone)) {
                            <a href="tel:@s.BackupEmployee.Phone" class="text-decoration-none small text-muted">
                              <i class="bi bi-telephone-fill me-1 text-warning" style="font-size:.65rem"></i>@s.BackupEmployee.Phone
                            </a>
                          } else {
                            <span class="small text-muted">No phone</span>
                          }
                        </div>
                      </div>
                    } else { <span class="text-muted">—</span> }
                  </td>
                  <td><span class="badge-status badge-@s.Status.ToLower()">@s.Status</span></td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      }
    </div>
  </div>

</div>