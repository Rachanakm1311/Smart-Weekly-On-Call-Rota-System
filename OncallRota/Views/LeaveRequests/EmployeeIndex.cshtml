@model IEnumerable<OncallRota.Models.LeaveRequest>
@{ Layout="_EmployeeLayout"; ViewData["Title"]="My Leave Requests"; }
<div class="page-header">
  <div class="d-flex align-items-center justify-content-between">
    <h1 class="page-title"><i class="bi bi-calendar-minus me-2 text-primary"></i>My Leave Requests</h1>
    <a asp-action="Apply" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Apply Leave</a>
  </div>
</div>
<div class="page-body">
  <div class="card"><div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover datatable mb-0 align-middle">
        <thead class="table-light">
          <tr><th>#</th><th>Type</th><th>Start</th><th>End</th><th>Reason</th><th>Comp-Off</th><th>Status</th></tr>
        </thead>
        <tbody>
          @{ int i=1; }
          @foreach(var l in Model){
            <tr>
              <td class="text-muted">@(i++)</td>
              <td>
                @if (l.WorkOnHoliday) {
                  <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                    <i class="bi bi-brightness-high-fill me-1"></i>Holiday Work
                  </span>
                } else {
                  <span class="badge bg-secondary-subtle text-secondary border">@l.LeaveType</span>
                }
              </td>
              <td>@l.StartDate?.ToString("dd MMM yyyy")</td>
              <td>@l.EndDate?.ToString("dd MMM yyyy")</td>
              <td class="small text-muted">@(l.Reason??"—")</td>
              <td class="small">
                @if (l.WorkOnHoliday && l.CompOffDate.HasValue) {
                  <span class="badge border" style="background:#e6fff9;color:#0f766e;border-color:#99f6e4!important">
                    <i class="bi bi-calendar2-check me-1"></i>@l.CompOffDate.Value.ToString("dd MMM yyyy")
                  </span>
                } else {
                  <span class="text-muted">—</span>
                }
              </td>
              <td><span class="badge-status badge-@l.Status.ToLower()">@l.Status</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div></div>
</div>
