@model IEnumerable<OncallRota.Models.LeaveRequest>
@{ Layout="_AdminLayout"; ViewData["Title"]="Leave Requests (Admin)"; }
<div class="page-header">
  <h1 class="page-title"><i class="bi bi-calendar-minus me-2 text-primary"></i>Leave Requests</h1>
</div>
<div class="page-body">
  <div class="card"><div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover datatable mb-0 align-middle">
        <thead class="table-light">
          <tr><th>#</th><th>Employee</th><th>Type</th><th>Start</th><th>End</th><th>Reason</th><th>Comp-Off</th><th>Status</th><th class="text-end">Actions</th></tr>
        </thead>
        <tbody>
          @{ int i=1; }
          @foreach(var l in Model){
            <tr>
              <td class="text-muted">@(i++)</td>
              <td class="fw-semibold">@l.Employee?.EmployeeName</td>
              <td>
                @if (l.WorkOnHoliday) {
                  <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                    <i class="bi bi-brightness-high-fill me-1"></i>Holiday Work
                  </span>
                } else {
                  <span class="badge bg-secondary-subtle text-secondary border">@l.LeaveType</span>
                }
              </td>
              <td class="small">@l.StartDate?.ToString("dd MMM yyyy")</td>
              <td class="small">@l.EndDate?.ToString("dd MMM yyyy")</td>
              <td class="small text-muted">@(l.Reason?.Length>30?l.Reason[..30]+"…":l.Reason??"—")</td>
              <td class="small">
                @if (l.WorkOnHoliday && l.CompOffDate.HasValue) {
                  <span class="badge bg-teal-subtle border" style="background:#e6fff9;color:#0f766e;border-color:#99f6e4!important">
                    <i class="bi bi-calendar2-check me-1"></i>@l.CompOffDate.Value.ToString("dd MMM yyyy")
                  </span>
                } else {
                  <span class="text-muted">—</span>
                }
              </td>
              <td><span class="badge-status badge-@l.Status.ToLower()">@l.Status</span></td>
              <td class="text-end">
                @if(l.Status=="Pending"){
                  <form asp-action="Approve" asp-route-id="@l.LeaveId" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-xs btn-success" data-confirm="Approve this leave?"><i class="bi bi-check-lg"></i> Approve</button>
                  </form>
                  <form asp-action="Reject" asp-route-id="@l.LeaveId" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-xs btn-danger" data-confirm="Reject this leave?"><i class="bi bi-x-lg"></i> Reject</button>
                  </form>
                } else {
                  <span class="text-muted small">@(l.ApprovedBy ?? "—")</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div></div>
</div>
